{
  "expo": {
    "name": "AltoWIFI",
    "slug": "altowifiapp",
    "owner": "sidhanie",
    "version": "2.5.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.altomedia.altowifi",
      "infoPlist": {
        "NSCameraUsageDescription": "AltoWIFI membutuhkan akses kamera untuk scan QR code WiFi",
        "NSMicrophoneUsageDescription": "AltoWIFI membutuhkan akses mikrofon untuk fitur voice",
        "NSLocationWhenInUseUsageDescription": "AltoWIFI membutuhkan lokasi untuk mendeteksi jaringan WiFi terdekat",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "AltoWIFI membutuhkan lokasi untuk monitoring jaringan WiFi",
        "NSContactsUsageDescription": "AltoWIFI membutuhkan akses kontak untuk mengelola data pelanggan",
        "NSPhotoLibraryUsageDescription": "AltoWIFI membutuhkan akses galeri untuk menyimpan struk voucher"
      }
    },
    "android": {
      "package": "com.altomedia.altowifi",
      "versionCode": 1,
      "minSdkVersion": 26,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_STATE",
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_CONTACTS",
        "WRITE_CONTACTS",
        "SEND_SMS",
        "READ_SMS",
        "RECEIVE_SMS",
        "READ_PHONE_STATE",
        "CALL_PHONE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "NFC",
        "FLASHLIGHT",
        "FOREGROUND_SERVICE"
      ]
    },
    "platforms": ["android", "ios"],
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c8be9f9c-0e6c-496a-8b90-164370e69f4a"
      }
    },
    "scheme": "altowifi"
  }
}
